# ─────────────────────────────────────────────────────────────
# The Living Archive — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Groq API key (get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# URL of your running TTS server (tts-server/main.py)
# Locally:  http://localhost:8000
# Deployed: https://your-tts-server.railway.app
TTS_SERVER_URL=http://localhost:8000
